# Backend API Configuration

# Server port (default: 3001)
PORT=3001

# Environment
NODE_ENV=development

# JWT Secret for token authentication
# ⚠️ IMPORTANT: Generate a secure key and keep it secret!
# Generate command: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_secure_jwt_secret_here_min_32_chars

# MAX Messenger Integration (optional)
# Token for MAX Messenger API authentication
MAX_MESSENGER_TOKEN=your_max_api_token_here

# Chat IDs for MAX Messenger notifications (comma-separated)
# Example: 123456789,987654321
MAX_MESSENGER_CHAT_IDS=your_chat_id_here
